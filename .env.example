# ==================================================
# CottonPulseBot — Environment Configuration
# ==================================================

# Required: Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here

# Optional: Admin Telegram user IDs (comma-separated)
# Used for /status and admin-only features
ADMIN_IDS=123456789

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL=300

# Optional: Alert check interval in seconds (default: 60)
ALERT_CHECK_INTERVAL=60

# Optional: Rate limit — seconds between user requests (default: 2)
USER_RATE_LIMIT=2

# Optional: Max alerts per user (default: 10)
MAX_ALERTS_PER_USER=10

# Optional: Alert cooldown minutes — min interval between same alert fires (default: 30)
ALERT_COOLDOWN_MINUTES=30

# Optional: Proxy URL for HTTP requests (if needed)
# HTTP_PROXY=http://user:pass@host:port

# ==================================================
# Multi-source API keys (all optional — free tiers)
# ==================================================

# Quandl / Nasdaq Data Link  → https://data.nasdaq.com/sign-up
# QUANDL_API_KEY=your_quandl_key_here

# USDA NASS  → https://quickstats.nass.usda.gov/api
# USDA_API_KEY=your_usda_key_here

# FRED (St. Louis Fed)  → https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_fred_key_here

# ==================================================
# Consensus / scraping tuning (optional)
# ==================================================

# Minimum number of sources required to publish a consensus price
# CONSENSUS_MIN_SOURCES=2

# Maximum allowed price spread before confidence is penalised (percent)
# CONSENSUS_MAX_DEVIATION=5.0

# Wall-clock timeout for the parallel fetch (seconds)
# CONSENSUS_TIMEOUT=25.0
